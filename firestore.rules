rules_version = '2';

// Booking-embed Firestore security model (multi-tenant).
//
// Principle: ALL data access — public booking flow AND admin — is mediated by
// the `api` Cloud Function using the Admin SDK, which BYPASSES these rules. The
// web client touches Firestore only for Google sign-in (Firebase Auth), never to
// read or write tenant data. So the correct, strictly-safe posture is to DENY
// every direct client read/write. This makes cross-tenant leakage impossible at
// the rules layer regardless of any future client-config exposure; per-tenant
// authorization is enforced in the API (requireAdmin resolves the caller's role
// within the path's tenant).
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-tenant data: the tenant doc (branding folded in) + every subcollection
    // (members, members/*/connections, eventTypes, availabilitySchedules,
    // bookings, slotLocks, dayCounters, reminderSends). Server-only.
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if false;
    }

    // Platform-level: hashed signup access codes + short-lived OAuth state.
    match /signupCodes/{doc} {
      allow read, write: if false;
    }
    match /oauthStates/{doc} {
      allow read, write: if false;
    }

    // Deny everything else, including the legacy root collections that the
    // migration leaves intact for rollback (branding, members, eventTypes,
    // availabilitySchedules, bookings, slotLocks, dayCounters, private/*).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
