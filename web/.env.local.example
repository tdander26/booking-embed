# Copy to .env.local and fill in. These are PUBLIC Firebase web config values
# (safe to ship to the browser — access is gated by Firestore rules + App Check,
# not by hiding these).
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=

# Set to "1" to connect the web app to local emulators (Auth + Firestore).
# Leave empty/unset for production.
VITE_USE_EMULATORS=1
